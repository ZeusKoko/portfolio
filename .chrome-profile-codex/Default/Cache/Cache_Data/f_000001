    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');
        
        :root {
            --olive-deep: #40513B;
            --olive-green: #628141;
            --parchment: #E5D9B6;
            --burnt-orange: #E67E22;
            --ink: #151713;
            --neon-blue: var(--burnt-orange);
            --electric-purple: var(--olive-green);
            --cyber-yellow: var(--parchment);
            --dark-bg: var(--ink);
        }
        
        body {
            font-family: 'Space Grotesk', sans-serif;
            background-color: var(--dark-bg);
            color: var(--parchment);
            overflow-x: hidden;
            scroll-behavior: smooth;
        }
        
        .hero-bg {
            background: var(--ink);
        }
        
        .neon-text {
            color: var(--burnt-orange);
            text-shadow: 0 0 18px rgba(230, 126, 34, 0.22);
        }
        
        .purple-glow {
            box-shadow: 0 12px 30px rgba(98, 129, 65, 0.28);
        }
        
        .yellow-glow {
            box-shadow: 0 0 15px rgba(229, 217, 182, 0.3);
        }
        
        .skill-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(179, 0, 255, 0.3);
        }
        
        .project-card {
            transition: all 0.3s ease;
            background: linear-gradient(145deg, #111111, #0a0a0a);
        }
        
        .project-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 30px rgba(0, 247, 255, 0.1);
        }
        
        .service-card {
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }
        
        .service-card:hover {
            border-color: var(--neon-blue);
            transform: scale(1.03);
        }
        
        .input-field {
            background-color: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }
        
        .input-field:focus {
            border-color: var(--neon-blue);
            box-shadow: 0 0 0 2px rgba(0, 247, 255, 0.2);
        }
        
        .nav-link {
            position: relative;
        }
        
        .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -2px;
            left: 0;
            background-color: var(--burnt-orange);
            transition: width 0.3s ease;
        }
        
        .nav-link:hover::after {
            width: 100%;
        }
        
        .animate-float {
            animation: float 3s ease-in-out infinite;
        }
        
        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
            100% { transform: translateY(0px); }
        }
        
        .grid-pattern {
            background-image: 
                linear-gradient(rgba(229, 217, 182, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(229, 217, 182, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        .portfolio-nav {
            background: rgba(21, 23, 19, 0.74);
            border-bottom: 1px solid rgba(229, 217, 182, 0.16);
        }

        .hero-video {
            filter: saturate(0.88) contrast(1.08);
        }

        .hero-overlay {
            background:
                radial-gradient(circle at 50% 38%, rgba(98, 129, 65, 0.52), transparent 46%),
                linear-gradient(180deg, rgba(21, 23, 19, 0.86) 0%, rgba(64, 81, 59, 0.58) 44%, rgba(21, 23, 19, 0.98) 100%);
        }

        .hero-media-stage {
            background: rgba(229, 217, 182, 0.08);
            border: 1px solid rgba(229, 217, 182, 0.18);
            border-radius: 8px;
            box-shadow: 0 36px 90px rgba(0, 0, 0, 0.36);
            overflow: hidden;
        }

        .hero-media-stage::after {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            background:
                linear-gradient(90deg, rgba(21, 23, 19, 0.36), transparent 24%, transparent 76%, rgba(21, 23, 19, 0.28)),
                linear-gradient(180deg, transparent 58%, rgba(21, 23, 19, 0.64));
        }

        .tech-strip {
            background: rgba(229, 217, 182, 0.94);
            color: var(--ink);
            border-radius: 999px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.24);
        }

        .tech-pill {
            border-right: 1px solid rgba(21, 23, 19, 0.16);
        }

        .tech-pill:last-child {
            border-right: 0;
        }

        .hero-title {
            line-height: 0.84;
            letter-spacing: 0;
            text-transform: uppercase;
        }

        .hero-outline {
            color: transparent;
            -webkit-text-stroke: 1px rgba(229, 217, 182, 0.72);
            text-stroke: 1px rgba(229, 217, 182, 0.72);
        }

        .hero-kicker {
            color: var(--parchment);
            border: 1px solid rgba(229, 217, 182, 0.32);
            background: rgba(64, 81, 59, 0.72);
        }

        .portfolio-button {
            border: 1px solid rgba(229, 217, 182, 0.35);
            border-radius: 4px;
            color: var(--parchment);
            transition: all 0.25s ease;
        }

        .portfolio-button:hover {
            border-color: var(--burnt-orange);
            background: rgba(230, 126, 34, 0.14);
            color: #ffffff;
        }

        .portfolio-button-primary {
            background: var(--burnt-orange);
            border-color: var(--burnt-orange);
            color: var(--ink);
        }

        .portfolio-button-primary:hover {
            background: var(--parchment);
            border-color: var(--parchment);
            color: var(--ink);
        }

        .hero-stat {
            border-left: 2px solid var(--burnt-orange);
            background: rgba(21, 23, 19, 0.54);
        }

        .service-marquee {
            background: var(--burnt-orange);
            color: var(--ink);
            border-top: 1px solid rgba(21, 23, 19, 0.32);
            border-bottom: 1px solid rgba(21, 23, 19, 0.32);
            white-space: nowrap;
            transform: rotate(-5deg);
            transform-origin: center;
            box-shadow: 0 22px 44px rgba(0, 0, 0, 0.28);
        }

        .service-marquee-track {
            animation: marquee 24s linear infinite;
        }

        @keyframes marquee {
            from { transform: translateX(0); }
            to { transform: translateX(-50%); }
        }
        
        .gallery-item {
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .gallery-item:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 25px rgba(0, 247, 255, 0.3);
        }
        
        #lightbox {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            z-index: 1000;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        #lightbox.show {
            display: flex;
            opacity: 1;
        }
        
        #lightbox img {
            max-width: 90%;
            max-height: 90%;
            object-fit: contain;
            margin: auto;
        }
        
        #lightbox-close {
            position: absolute;
            top: 20px;
            right: 30px;
            color: white;
            font-size: 30px;
            cursor: pointer;
            z-index: 1001;
        }
    </style>
